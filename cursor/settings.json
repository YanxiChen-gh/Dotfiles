{
    "vim.easymotion": true,
    "vim.enableNeovim": true,
    "vim.smartRelativeLine": true,
    "vim.targets.enable": true,
    "vim.leader": " ",
    "vim.hlsearch": true,
    "vim.commandLineModeKeyBindings": [],
    "vim.visualModeKeyBindingsNonRecursive": [
        {
            "before": ["<leader>", "g", "r"],
            "commands": ["git.revertSelectedRanges"]
        },
        {
            "before": ["leader", "j"],
            "after": ["leader", "leader", "l"]
        },
        {
            "before": ["leader", "k"],
            "after": ["leader", "leader", "h"]
        }
    ],
    "vim.insertModeKeyBindingsNonRecursive": [
        {
            "before": ["j", "j"],
            "after": ["<Esc>"]
        },
        {
            "before": ["<C-h>"],
            "after": ["<left>"]
        },
        {
            "before": ["<C-j>"],
            "after": ["<down>"]
        },
        {
            "before": ["<C-k>"],
            "after": ["<up>"]
        },
        {
            "before": ["<C-l>"],
            "after": ["<right>"]
        },
        {
            "before": ["<c-f>"],
            "after": ["<s-right>"]
        },
        {
            "before": ["<c-b>"],
            "after": ["<s-left>"]
        },
        {
            "before": ["<c-a>"],
            "after": ["<home>"]
        },
        {
            "before": ["<c-e>"],
            "after": ["<end>"]
        },
        {
            "before": ["<c-d>"],
            "after": ["<del>"]
        },
        {
            "before": ["<M-h>"],
            "after": ["<esc>", "g", "T"]
        },
        {
            "before": ["<M-l>"],
            "after": ["<esc>", "g", "t"]
        },
        {
            "before": ["<silent>", "<expr>"],
            "after": ["<TAB>"]
        }
    ],
    "vim.normalModeKeyBindingsNonRecursive": [
        {
            "before": [";"],
            "after": [":"]
        },
        {
            "before": ["<leader>", "f", "d"],
            "commands": [
                { "command": "editor.action.addSelectionToNextFindMatch", "args": [] },
                { "command": "workbench.action.findInFiles" }
            ]
        },
        {
            "before": ["g", "r"],
            "commands": ["editor.action.goToReferences"]
        },
        {
            "before": ["g", "i"],
            "commands": ["editor.action.goToImplementation"]
        },
        {
            "before": ["<leader>", "g", "d"],
            "commands": ["editor.action.dirtydiff.next"]
        },
        {
            "before": ["<leader>", "g", "r"],
            "commands": ["git.revertSelectedRanges"]
        },
        {
            "before": ["="],
            "commands": ["workbench.action.editor.nextChange"]
        },
        {
            "before": ["-"],
            "commands": ["workbench.action.editor.previousChange"]
        },
        {
            "before": ["]", "c"],
            "commands": ["go-to-next-error.nextInFiles.error"],
            "silent": true
        },
        {
            "before": ["[", "c"],
            "commands": ["go-to-next-error.prevInFiles.error"],
            "silent": true
        },
        {
            "before": ["leader", "j"],
            "after": ["leader", "leader", "l"]
        },
        {
            "before": ["leader", "k"],
            "after": ["leader", "leader", "h"]
        }
    ],

    "workbench.iconTheme": "vscode-icons",
    "terminal.integrated.copyOnSelection": true,
    "terminal.integrated.fontFamily": "MesloLGS NF",
    "terminal.integrated.defaultProfile.linux": "zsh",
    "terminal.integrated.enableMultiLinePasteWarning": "never",
    "terminal.integrated.suggest.inlineSuggestion": "off",
    "workbench.colorCustomizations": {
        "terminal.findMatchBackground": "#ff0000",
        "terminal.findMatchBorder": "#ff0000",
        "terminal.findMatchHighlightBackground": "#ff0000",
        "terminal.findMatchHighlightBorder": "#ff0000",
        "terminalOverviewRuler.findMatchForeground": "#ff0000"
    },

    "git.enableSmartCommit": true,
    "git.confirmSync": false,
    "git.autofetch": true,
    "git.replaceTagsWhenPull": true,
    "githubPullRequests.pullBranch": "never",

    "editor.suggest.showEnumMembers": false,
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[jsonc]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[html]": {
        "editor.defaultFormatter": "rvest.vs-code-prettier-eslint"
    },
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "rvest.vs-code-prettier-eslint"
    },
    "[csharp]": {
        "editor.defaultFormatter": "ms-dotnettools.csharp"
    },
    "json.schemas": [],
    "eslint.codeActionsOnSave.rules": null,
    "svelte.enable-ts-plugin": true,

    "gitlens.ai.model": "vscode",
    "gitlens.ai.vscode.model": "copilot:gpt-4.1",

    "claudeCode.useTerminal": true,
    "claudeCode.preferredLocation": "panel",

    "github.copilot.nextEditSuggestions.enabled": true,
    "chat.mcp.autostart": "newAndOutdated",

    "remote.autoForwardPortsSource": "hybrid",
    "debug.javascript.autoAttachFilter": "smart",
    "task.allowAutomaticTasks": "on",
    "vsicons.dontShowNewVersionMessage": true,
    "redhat.telemetry.enabled": false,
    "dotnetAcquisitionExtension.existingDotnetPath": [],

    "remote.SSH.remotePlatform": {
        "*.gitpod.local": "linux",
        "*.gitpod.remote": "linux"
    }
}

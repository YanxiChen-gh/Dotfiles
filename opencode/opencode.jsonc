{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.6-sol",
  "plugin": ["opencode-claude-auth@1.5.4"],
  "agent": {
    "build": {
      "model": "openai/gpt-5.6-sol",
      "variant": "high"
    },
    "plan": {
      "model": "openai/gpt-5.6-sol",
      "variant": "high"
    },
    "general": {
      "model": "openai/gpt-5.6-sol",
      "variant": "high"
    },
    "explore": {
      "model": "openai/gpt-5.6-sol",
      "variant": "high"
    }
  },
  "provider": {
    "openai": {
      "models": {
        "gpt-5.6-sol": {
          "variants": {
            "fast": {
              "serviceTier": "priority"
            }
          }
        },
        "gpt-5.6-terra": {
          "variants": {
            "fast": {
              "serviceTier": "priority"
            }
          }
        },
        "gpt-5.6-luna": {
          "variants": {
            "fast": {
              "serviceTier": "priority"
            }
          }
        }
      }
    }
  }
}
